# ==========================================================================
# REGULR.vip - Apache Configuration
# Security headers, rewrite rules, and access restrictions
# ==========================================================================

# --- ENABLE REWRITE ENGINE ---
RewriteEngine On

# --- FORCE HTTPS (safe for .test/.local dev domains) ---
RewriteCond %{HTTPS} off
RewriteCond %{HTTP_HOST} !^localhost [NC]
RewriteCond %{HTTP_HOST} !\.local$ [NC]
RewriteCond %{HTTP_HOST} !\.test$ [NC]
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# --- SET BASE PATH (adjust if in subdirectory on Hostinger) ---
# Lokaal:  RewriteBase /
# Productie (subdirectory): RewriteBase /app/
# RewriteBase /

# --- SECURITY HEADERS ---
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Permissions-Policy "camera=(self), geolocation=()"
    # Remove server signature
    Header unset Server
    ServerSignature Off
</IfModule>

# --- BLOCK ACCESS TO SENSITIVE FILES ---
# Block direct access to config, models, services, middleware, utils, views, sql
# Exception: sql/web_migrate.php is allowed (browser-accessible migration runner)
RewriteRule ^sql/web_migrate\.php$ - [L]
RewriteRule ^config/ - [F,L]
RewriteRule ^models/ - [F,L]
RewriteRule ^services/ - [F,L]
RewriteRule ^middleware/ - [F,L]
RewriteRule ^utils/ - [F,L]
RewriteRule ^views/ - [F,L]
RewriteRule ^sql/ - [F,L]

# Block hidden files (.env, .git, .htaccess itself from listing)
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# Block access to sensitive file types
<FilesMatch "\.(sql|log|env|yml|yaml|json|lock|md)$">
    Require all denied
</FilesMatch>

# Block access to CLI-only emergency/admin scripts (defense in depth)
<FilesMatch "^(emergency_token|emergency_reset|create_admin|reset_admin_password|gen_token|pre_deploy_token)\.php$">
    Require all denied
</FilesMatch>

# Allow manifest.json.php for PWA
<FilesMatch "manifest\.json\.php$">
    Require all granted
</FilesMatch>

# Allow sw.js service worker with expanded scope
<FilesMatch "sw\.js$">
    Header set Service-Worker-Allowed "/"
</FilesMatch>

# --- ROUTING ---
# Serve favicon.ico from public/ directory
RewriteRule ^favicon\.ico$ public/favicon.ico [L]

# Route all requests (except existing files and public/) through index.php
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !^/public/
RewriteRule ^(.*)$ index.php?route=$1 [QSA,L]

# --- PHP SETTINGS (if allowed by host) ---
<IfModule mod_php.c>
    php_value session.cookie_httponly 1
    # session.cookie_secure is set dynamically in index.php based on APP_DEBUG
    # Do NOT hardcode to 1 here — breaks HTTP development environments
    php_value session.use_strict_mode 1
    php_value session.cookie_samesite "Strict"
    php_value expose_php 0
</IfModule>

# --- DEFAULT CHARSET ---
AddDefaultCharset UTF-8

# --- GZIP COMPRESSION ---
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css application/json application/javascript text/xml
</IfModule>

# --- BROWSER CACHING for static assets ---
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
</IfModule>
